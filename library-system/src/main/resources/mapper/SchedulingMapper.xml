<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.SchedulingMapper">
    <select id="findById" resultType="com.library.entity.Scheduling">
        SELECT * FROM scheduling WHERE id = #{id}
    </select>

    <select id="findAll" resultType="com.library.entity.Scheduling">
        SELECT * FROM scheduling
    </select>

    <select id="findBySeatId" resultType="com.library.entity.Scheduling">
        SELECT * FROM scheduling WHERE seat_id = #{seatId}
    </select>

    <select id="findByReaderId" resultType="com.library.entity.Scheduling">
        SELECT * FROM scheduling WHERE reader_id = #{readerId}
    </select>

    <select id="findByStatus" resultType="com.library.entity.Scheduling">
        SELECT * FROM scheduling WHERE status = #{status}
    </select>

    <insert id="insert" parameterType="com.library.entity.Scheduling">
        INSERT INTO scheduling (seat_id, reader_id, start_time, end_time, status)
        VALUES (#{seatId}, #{readerId}, #{startTime}, #{endTime}, #{status})
    </insert>

    <update id="update" parameterType="com.library.entity.Scheduling">
        UPDATE scheduling SET
        seat_id = #{seatId},
        reader_id = #{readerId},
        start_time = #{startTime},
        end_time = #{endTime},
        status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM scheduling WHERE id = #{id}
    </delete>

    <update id="updateStatus">
        UPDATE scheduling SET status = #{status} WHERE id = #{id}
    </update>
</mapper>
