<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.AdminMapper">
    <select id="findByUsername" resultType="com.library.entity.Admin">
        SELECT * FROM admin WHERE username = #{username}
    </select>

    <select id="findAll" resultType="com.library.entity.Admin">
        SELECT * FROM admin
    </select>

    <insert id="insert" parameterType="com.library.entity.Admin">
        INSERT INTO admin (username, password, real_name, phone, email)
        VALUES (#{username}, #{password}, #{realName}, #{phone}, #{email})
    </insert>

    <update id="update" parameterType="com.library.entity.Admin">
        UPDATE admin
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM admin WHERE id = #{id}
    </delete>
</mapper>
